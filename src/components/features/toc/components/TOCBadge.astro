---
/**
 * TOC badge component
 * number, dot, and small-dot variants
 */

export type BadgeVariant = "number" | "dot" | "dot-small";

export interface Props {
	/** Badge text (number variant only) */
	text?: string;
	/** Badge variant */
	variant?: BadgeVariant;
	/** Active state */
	active?: boolean;
}

const { text = "", variant = "number", active = false } = Astro.props;
---

{
	variant === "number" && (
		<span class:list={["toc-badge", active && "active"]}>{text}</span>
	)
}
{variant === "dot" && <span class:list={["toc-dot", active && "active"]} />}
{
	variant === "dot-small" && (
		<span class:list={["toc-dot-small", active && "active"]} />
	)
}

<style>
	.toc-badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 1.25rem;
		height: 1.25rem;
		padding: 0 0.25rem;
		border-radius: 0.25rem;
		background: var(--toc-badge-bg);
		color: var(--btn-content);
		font-size: 0.75rem;
		font-weight: bold;
		flex-shrink: 0;
		transition: all 0.2s ease;
	}

	.toc-badge.active {
		background: var(--primary);
		color: white;
	}

	.toc-dot {
		display: inline-block;
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 50%;
		background: var(--line-divider);
		flex-shrink: 0;
		transition: all 0.2s ease;
	}

	.toc-dot.active {
		background: var(--primary);
	}

	.toc-dot-small {
		display: inline-block;
		width: 0.35rem;
		height: 0.35rem;
		border-radius: 50%;
		background: var(--line-divider);
		flex-shrink: 0;
		transition: all 0.2s ease;
	}

	:global(.dark) .toc-dot-small {
		background: rgba(255, 255, 255, 0.1);
	}

	.toc-dot-small.active {
		background: var(--primary);
	}
</style>

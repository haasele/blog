---
import MovieCard from "./MovieCard.astro";

interface StatusInfo {
	text: string;
	class: string;
	icon: string;
}

interface MovieItem {
	title: string;
	cover: string;
	link: string;
	status: string;
	rating: number;
	progress: number;
	totalEpisodes: number;
	description: string;
	year: string;
	studio: string;
	genre: string[];
}

interface Props {
	visibleMovieList: MovieItem[];
	hiddenMovieList: MovieItem[];
	statusMap: Record<string, StatusInfo>;
	yearLabel: string;
	studioLabel: string;
}

const { visibleMovieList, hiddenMovieList, statusMap, yearLabel, studioLabel } =
	Astro.props;

const hasHiddenItems = hiddenMovieList.length > 0;
---

<div
	id="movie-list-container"
	class="movie-grid-container grid gap-4 md:gap-6 opacity-0 transition-opacity duration-300"
>
	{
		visibleMovieList.map((movie) => {
			const statusInfo = statusMap[movie.status] || {
				text: movie.status,
				class: "btn-regular",
				icon: "?",
			};
			return (
				<MovieCard
					movie={movie}
					statusInfo={statusInfo}
					yearLabel={yearLabel}
					studioLabel={studioLabel}
				/>
			);
		})
	}
</div>

<template id="movie-lazy-store">
	{
		hiddenMovieList.map((movie) => {
			const statusInfo = statusMap[movie.status] || {
				text: movie.status,
				class: "btn-regular",
				icon: "?",
			};
			return (
				<MovieCard
					movie={movie}
					statusInfo={statusInfo}
					yearLabel={yearLabel}
					studioLabel={studioLabel}
				/>
			);
		})
	}
</template>

{
	hasHiddenItems && (
		<div
			id="infinite-scroll-sentinel"
			class="w-full h-20 flex items-center justify-center mt-8"
		>
			<div class="movie-loading-spinner w-8 h-8 border-4 border-[var(--primary)] border-t-transparent rounded-full animate-spin" />
		</div>
	)
}

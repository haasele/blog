---
// Load only base monospace fonts to reduce load time
import "@fontsource-variable/jetbrains-mono/wght-italic.css";

interface Props {
	class: string;
}
const className = Astro.props.class;
---

<div
	data-pagefind-body
	class={`prose dark:prose-invert prose-base !max-w-none custom-md ${className}`}
>
	<!--<div class="prose dark:prose-invert max-w-none custom-md">-->
	<!--<div class="max-w-none custom-md">-->
	<slot />
</div>

<script>
	document.addEventListener("click", function (e: MouseEvent) {
		const target = e.target as Element | null;
		if (target && target.classList.contains("copy-btn")) {
			const codeEle = target.parentElement?.querySelector("code");

			// Precise code extraction
			let code = "";
			if (codeEle) {
				// Get all code line elements
				const lineElements = codeEle.querySelectorAll("span.line");
				if (lineElements.length > 0) {
					// For line-structured blocks, process each line
					const lines: string[] = [];
					for (let i = 0; i < lineElements.length; i++) {
						const lineElement = lineElements[i];
						// Raw text content, no extra processing
						const lineText = lineElement.textContent || "";
						lines.push(lineText);
					}
					// Join lines with \n, not \n\n
					code = lines.join("\n");
				} else {
					// Blocks without line structure
					const codeElements = codeEle.querySelectorAll(
						".code:not(summary *)",
					);
					if (codeElements.length > 0) {
						const lines: string[] = [];
						for (let i = 0; i < codeElements.length; i++) {
							const el = codeElements[i];
							const lineText = el.textContent || "";
							lines.push(lineText);
						}
						code = lines.join("\n");
					} else {
						// Fallback: entire code element text
						code = codeEle.textContent || "";
					}
				}
			}

			// Collapse consecutive blank lines (improved logic)
			code = code.replace(/\n\n\n+/g, function (match) {
				// Count consecutive newlines
				const newlineCount = match.length;
				// Blank line count (newlines - 1)
				const emptyLineCount = newlineCount - 1;

				// Even blank lines: divide by 2
				// Odd blank lines: floor((count + 1) / 2)
				let resultEmptyLines: number;
				if (emptyLineCount % 2 === 0) {
					// even
					resultEmptyLines = emptyLineCount / 2;
				} else {
					// odd
					resultEmptyLines = Math.floor((emptyLineCount + 1) / 2);
				}

				// Keep at least one blank line
				if (resultEmptyLines < 1) {
					resultEmptyLines = 1;
				}

				// Return matching newlines
				return "\n".repeat(resultEmptyLines + 1);
			});

			const copyToClipboard = async (text: string) => {
				if (!navigator.clipboard?.writeText) {
					throw new Error("Clipboard API is not available");
				}

				await navigator.clipboard.writeText(text);
			};

			copyToClipboard(code)
				.then(() => {
					const timeoutId = target.getAttribute("data-timeout-id");
					if (timeoutId) {
						clearTimeout(parseInt(timeoutId));
					}

					target.classList.add("success");

					// Set timeout and store id on button dataset
					const newTimeoutId = setTimeout(() => {
						target.classList.remove("success");
					}, 1000);

					target.setAttribute(
						"data-timeout-id",
						newTimeoutId.toString(),
					);
				})
				.catch((err) => {
					console.error("Copy failed:", err);
					// User-facing error hint could go here
				});
		}
	});
</script>

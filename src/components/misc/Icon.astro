---
/**
 * Icon component - backward-compatible wrapper
 *
 * Wraps atoms/Icon/ for backward compatibility
 * New code should import from @components/atoms/Icon
 *
 * @deprecated Use import from "@components/atoms/Icon"
 */

import BaseIcon from "../atoms/Icon/Icon.astro";
import type { IconProps } from "../atoms/Icon/types";

export interface Props extends IconProps {}

const {
	icon,
	class: className = "",
	style = "",
	size = "md",
	color,
	fallback = "●",
	loading = "lazy",
} = Astro.props;
---

<BaseIcon
	icon={icon}
	class={className}
	style={style}
	size={size}
	color={color}
	fallback={fallback}
	loading={loading}
/>

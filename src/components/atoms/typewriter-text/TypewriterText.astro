---
export interface Props {
	text: string | string[];
	speed?: number;
	deleteSpeed?: number;
	pauseTime?: number;
	class?: string;
}

const {
	text,
	speed = 100,
	deleteSpeed = 50,
	pauseTime = 2000,
	class: className = "",
} = Astro.props;
const textData = Array.isArray(text) ? JSON.stringify(text) : text;
---

<span
	class={`typewriter ${className}`}
	data-text={textData}
	data-speed={speed}
	data-delete-speed={deleteSpeed}
	data-pause-time={pauseTime}></span>

<script>
	class TypewriterEffect {
		private element: HTMLElement;
		private texts: string[];
		private currentTextIndex = 0;
		private speed: number;
		private deleteSpeed: number;
		private pauseTime: number;
		private currentIndex = 0;
		private isDeleting = false;
		private timeoutId: number | null = null;

		constructor(element: HTMLElement) {
			this.element = element;
			const textData = element.dataset.text || "";

			// Parse JSON array or treat as single string
			try {
				const parsed = JSON.parse(textData);
				this.texts = Array.isArray(parsed) ? parsed : [textData];
			} catch {
				this.texts = [textData];
			}

			this.speed = parseInt(element.dataset.speed || "100");
			this.deleteSpeed = parseInt(element.dataset.deleteSpeed || "50");
			this.pauseTime = parseInt(element.dataset.pauseTime || "2000");

			// Multiple strings without typewriter: pick one at random
			if (this.texts.length > 1 && !this.isTypewriterEnabled()) {
				this.showRandomText();
			} else {
				this.start();
			}
		}

		private isTypewriterEnabled(): boolean {
			// Typewriter data attributes
			return (
				this.element.dataset.speed !== undefined ||
				this.element.dataset.deleteSpeed !== undefined ||
				this.element.dataset.pauseTime !== undefined
			);
		}

		private showRandomText() {
			const randomIndex = Math.floor(Math.random() * this.texts.length);
			this.element.textContent = this.texts[randomIndex];
		}

		private start() {
			if (this.texts.length === 0) {
				return;
			}
			this.type();
		}

		private getCurrentText(): string {
			return this.texts[this.currentTextIndex] || "";
		}

		private type() {
			const currentText = this.getCurrentText();

			if (this.isDeleting) {
				// Delete character
				if (this.currentIndex > 0) {
					this.currentIndex--;
					this.element.textContent = currentText.substring(
						0,
						this.currentIndex,
					);
					this.timeoutId = window.setTimeout(
						() => this.type(),
						this.deleteSpeed,
					);
				} else {
					// Done deleting; next string
					this.isDeleting = false;
					this.currentTextIndex =
						(this.currentTextIndex + 1) % this.texts.length;
					this.timeoutId = window.setTimeout(
						() => this.type(),
						this.speed,
					);
				}
			} else {
				// Add character
				if (this.currentIndex < currentText.length) {
					this.currentIndex++;
					this.element.textContent = currentText.substring(
						0,
						this.currentIndex,
					);
					this.timeoutId = window.setTimeout(
						() => this.type(),
						this.speed,
					);
				} else {
					// Typing done; pause then delete if multiple strings
					if (this.texts.length > 1) {
						this.isDeleting = true;
						this.timeoutId = window.setTimeout(
							() => this.type(),
							this.pauseTime,
						);
					} else {
						// Single string: keep visible; ensure non-empty layout
						if (this.texts.length === 1 && this.texts[0] === "") {
							this.element.innerHTML = "&nbsp;"; // NBSP preserves layout
						}
					}
				}
			}
		}

		public destroy() {
			if (this.timeoutId) {
				clearTimeout(this.timeoutId);
			}
		}
	}

	// Init all typewriters
	document.addEventListener("DOMContentLoaded", () => {
		const typewriterElements = document.querySelectorAll(".typewriter");
		typewriterElements.forEach((element) => {
			new TypewriterEffect(element as HTMLElement);
		});
	});

	// Re-init on page transition
	document.addEventListener("swup:contentReplaced", () => {
		const typewriterElements = document.querySelectorAll(".typewriter");
		typewriterElements.forEach((element) => {
			new TypewriterEffect(element as HTMLElement);
		});
	});
</script>

<style>
	.typewriter {
		position: relative;
		min-height: 1.5em; /* Min height when empty */
		display: inline-block;
		vertical-align: baseline;
	}

	/* Prevent layout shift from typewriter */
	.typewriter:empty::before {
		content: "\00A0"; /* NBSP for height */
		visibility: hidden;
	}
</style>

---
/**
 * Grid Scripts - inline scripts extracted from MainGridLayout
 * Wallpaper mode, layout switching, and Swup integration
 */

interface Props {
	navbarTransparentMode?: string;
	defaultWallpaperMode?: string;
	defaultPostListLayout?: string;
	BANNER_HEIGHT?: number;
	pageScaling?: { enable: boolean; targetWidth?: number };
}

const {
	navbarTransparentMode = "semi",
	defaultWallpaperMode = "banner",
	defaultPostListLayout = "list",
	BANNER_HEIGHT = 35,
	pageScaling = { enable: false },
} = Astro.props;
---

<script
	type="module"
	is:inline
	define:vars={{
		navbarTransparentMode,
		defaultWallpaperMode,
		defaultPostListLayout,
		BANNER_HEIGHT,
		pageScaling,
	}}
>
	// Run immediately before paint to apply wallpaper and layout modes and avoid flash
	(function () {
		const wallpaperMode =
			localStorage.getItem("wallpaperMode") || defaultWallpaperMode;
		const body = document.body;

		// Apply body classes immediately so first paint is correct
		switch (wallpaperMode) {
			case "banner":
				body.classList.add("enable-banner");
				body.classList.remove(
					"wallpaper-transparent",
					"no-banner-mode",
				);
				break;
			case "fullscreen":
				body.classList.remove("enable-banner");
				body.classList.add("wallpaper-transparent", "no-banner-mode");
				break;
			case "none":
				body.classList.remove("enable-banner", "wallpaper-transparent");
				body.classList.add("no-banner-mode");
				break;
		}

		// Adjust main content position and layout immediately (avoid flash and misplacement)
		// Use requestAnimationFrame to ensure DOM is ready
		requestAnimationFrame(function () {
			const mainContent = document.querySelector(
				".absolute.w-full.z-30.pointer-events-none",
			);
			if (mainContent) {
				if (wallpaperMode === "banner") {
					// Start main content at banner top so waves overlap the upper content
					mainContent.style.top = `${BANNER_HEIGHT}vh`;
				} else {
					// fullscreen or none mode
					mainContent.style.top = "5.5rem";
				}
			}

			// Apply layout mode immediately to avoid flash
			const mainGrid = document.getElementById("main-grid");
			if (mainGrid) {
				const savedLayout = localStorage.getItem("postListLayout");
				const currentLayout = savedLayout || defaultPostListLayout;
				mainGrid.setAttribute("data-layout-mode", currentLayout);

				// Show or hide right sidebar based on layout mode
				const rightSidebar = document.querySelector(
					".right-sidebar-container",
				);
				if (rightSidebar) {
					if (currentLayout === "grid") {
						rightSidebar.classList.add("hidden-in-grid-mode");
					} else {
						rightSidebar.classList.remove("hidden-in-grid-mode");
					}
				}

				// Also update post list container CSS classes
				const postListContainer = document.getElementById(
					"post-list-container",
				);
				if (postListContainer) {
					postListContainer.classList.remove(
						"list-mode",
						"grid-mode",
					);

					if (currentLayout === "grid") {
						postListContainer.classList.add("grid-mode");
						postListContainer.classList.add(
							"grid",
							"grid-cols-1",
							"lg:grid-cols-2",
							"gap-6",
						);
						postListContainer.classList.remove("flex", "flex-col");
					} else {
						postListContainer.classList.add("list-mode");
						postListContainer.classList.add("flex", "flex-col");
						postListContainer.classList.remove(
							"grid",
							"grid-cols-1",
							"lg:grid-cols-2",
							"gap-6",
						);
					}
				}
			}
		});
	})();

	// Toggle banner and fullscreen wallpaper based on wallpaper mode
	function applyWallpaperMode() {
		const wallpaperMode =
			localStorage.getItem("wallpaperMode") || defaultWallpaperMode;
		const bannerWrapper = document.getElementById("banner-wrapper");
		const fullscreenWallpaper = document.querySelector(
			"[data-fullscreen-wallpaper]",
		);
		const navbar = document.getElementById("navbar");
		const body = document.body;
		const mainContent = document.querySelector(
			".absolute.w-full.z-30.pointer-events-none",
		);
		const tocWrapper = document.getElementById("toc-wrapper");

		// Force reflow so styles apply correctly
		const forceReflow = function () {
			void document.body.offsetHeight;
		};

		switch (wallpaperMode) {
			case "banner":
				// Show banner, hide fullscreen wallpaper
				if (bannerWrapper) {
					bannerWrapper.style.display = "block";
				}
				if (fullscreenWallpaper) {
					fullscreenWallpaper.style.display = "none";
				}
				// Restore TOC hide state in banner mode; scroll logic takes over
				if (tocWrapper) {
					const scrollTop = document.documentElement.scrollTop;
					const bannerHeight =
						window.innerHeight * (BANNER_HEIGHT / 100);
					if (scrollTop <= bannerHeight) {
						tocWrapper.classList.add("toc-hide");
					}
				}
				// Remove body classes first to avoid CSS conflicts
				body.classList.remove("wallpaper-transparent");
				body.classList.remove("no-banner-mode");
				// Force reflow
				forceReflow();
				// Remove inline styles so CSS takes over
				if (mainContent) {
					mainContent.style.removeProperty("top");
				}
				// Then add enable-banner class
				body.classList.add("enable-banner");
				// Restore navbar transparent mode from config
				if (navbar) {
					navbar.removeAttribute("data-dynamic-transparent");
					// Restore data-transparent-mode from config
					navbar.setAttribute(
						"data-transparent-mode",
						navbarTransparentMode,
					);
					// Re-init scroll detection for semifull mode
					if (
						navbarTransparentMode === "semifull" &&
						window.initSemifullScrollDetection
					) {
						window.initSemifullScrollDetection();
					}
				}
				// Force reflow to refresh CSS variables
				forceReflow();
				break;

			case "fullscreen":
				// Hide banner, show fullscreen wallpaper
				if (bannerWrapper) {
					bannerWrapper.style.display = "none";
				}
				if (fullscreenWallpaper) {
					fullscreenWallpaper.style.display = "block";
				}
				// Always show TOC in fullscreen mode
				if (tocWrapper) {
					tocWrapper.classList.remove("toc-hide");
				}
				// Remove body classes first to avoid CSS conflicts
				body.classList.remove("enable-banner");
				// Force reflow
				forceReflow();
				// Remove inline styles so CSS takes over
				if (mainContent) {
					mainContent.style.removeProperty("top");
				}
				// Then add wallpaper-transparent and no-banner-mode classes
				body.classList.add("wallpaper-transparent");
				body.classList.add("no-banner-mode");
				// Force navbar to semi transparent (ignore config)
				if (navbar) {
					navbar.setAttribute("data-dynamic-transparent", "semi");
					// Remove data-transparent-mode from config influence
					navbar.removeAttribute("data-transparent-mode");
				}
				// Force reflow to refresh CSS variables
				forceReflow();
				break;

			case "none":
				// Hide all wallpapers
				if (bannerWrapper) {
					bannerWrapper.style.display = "none";
				}
				if (fullscreenWallpaper) {
					fullscreenWallpaper.style.display = "none";
				}
				// Always show TOC in no-wallpaper mode
				if (tocWrapper) {
					tocWrapper.classList.remove("toc-hide");
				}
				// Remove body classes first to avoid CSS conflicts
				body.classList.remove("enable-banner");
				body.classList.remove("wallpaper-transparent");
				// Force reflow
				forceReflow();
				// Remove inline styles so CSS takes over
				if (mainContent) {
					mainContent.style.removeProperty("top");
				}
				// Then add no-banner-mode class
				body.classList.add("no-banner-mode");
				// Force navbar opaque (ignore config)
				if (navbar) {
					navbar.setAttribute("data-dynamic-transparent", "none");
					// Remove data-transparent-mode from config influence
					navbar.removeAttribute("data-transparent-mode");
				}
				// Force reflow to refresh CSS variables
				forceReflow();
				break;
		}
	}

	// Listen for wallpaper mode changes and apply without reload
	window.addEventListener("wallpaper-mode-change", function (_event) {
		applyWallpaperMode();
	});

	// Run after DOM loads
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", applyWallpaperMode);
	} else {
		applyWallpaperMode();
	}

	// Swup: apply layout before content replace to avoid flash
	function setupSwupLayoutSync() {
		// @ts-ignore
		if (typeof window !== "undefined" && window.swup) {
			// Prepare layout before content:replace (animation:out:start)
			// @ts-ignore
			window.swup.hooks.on("animation:out:start", function () {
				// Save layout state for immediate apply on new page
				const savedLayout = localStorage.getItem("postListLayout");
				if (savedLayout) {
					// @ts-ignore
					window.__pendingLayoutMode = savedLayout;
				}
			});

			// Apply layout right after content replace, without waiting for other scripts
			// @ts-ignore
			window.swup.hooks.on("content:replace", function () {
				const mainGrid = document.getElementById("main-grid");
				if (mainGrid) {
					// @ts-ignore
					const currentLayout =
						window.__pendingLayoutMode ||
						localStorage.getItem("postListLayout") ||
						defaultPostListLayout;
					mainGrid.setAttribute("data-layout-mode", currentLayout);

					const rightSidebar = document.querySelector(
						".right-sidebar-container",
					);
					if (rightSidebar) {
						if (currentLayout === "grid") {
							rightSidebar.classList.add("hidden-in-grid-mode");
						} else {
							rightSidebar.classList.remove(
								"hidden-in-grid-mode",
							);
						}
					}

					// Also update post list container CSS classes
					const postListContainer = document.getElementById(
						"post-list-container",
					);
					if (postListContainer) {
						// Remove existing layout classes
						postListContainer.classList.remove(
							"list-mode",
							"grid-mode",
						);

						if (currentLayout === "grid") {
							postListContainer.classList.add("grid-mode");
							postListContainer.classList.add(
								"grid",
								"grid-cols-1",
								"lg:grid-cols-2",
								"gap-6",
							);
							postListContainer.classList.remove(
								"flex",
								"flex-col",
							);
						} else {
							postListContainer.classList.add("list-mode");
							postListContainer.classList.add("flex", "flex-col");
							postListContainer.classList.remove(
								"grid",
								"grid-cols-1",
								"lg:grid-cols-2",
								"gap-6",
							);
						}
					}

					// Clear temporary state
					// @ts-ignore
					delete window.__pendingLayoutMode;
				}
			});

			return true;
		}
		return false;
	}

	// Try setup immediately; retry with delay on failure
	if (!setupSwupLayoutSync()) {
		const checkSwup = setInterval(function () {
			if (setupSwupLayoutSync()) {
				clearInterval(checkSwup);
			}
		}, 50);

		setTimeout(function () {
			clearInterval(checkSwup);
		}, 2000);
	}

	// Swup page transition support
	document.addEventListener("swup:page:view", function () {
		applyWallpaperMode();

		// Re-apply layout mode on Swup page change
		requestAnimationFrame(function () {
			const mainGrid = document.getElementById("main-grid");
			if (mainGrid) {
				const savedLayout = localStorage.getItem("postListLayout");
				const currentLayout = savedLayout || defaultPostListLayout;
				mainGrid.setAttribute("data-layout-mode", currentLayout);

				if (currentLayout === "grid") {
					const rightSidebar = document.querySelector(
						".right-sidebar-container",
					);
					if (rightSidebar) {
						rightSidebar.classList.add("hidden-in-grid-mode");
					}
				} else {
					const rightSidebar = document.querySelector(
						".right-sidebar-container",
					);
					if (rightSidebar) {
						rightSidebar.classList.remove("hidden-in-grid-mode");
					}
				}
			}
		});
	});

	// After full load, confirm layout mode is correct
	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", function () {
			const mainGrid = document.getElementById("main-grid");
			if (mainGrid) {
				const savedLayout = localStorage.getItem("postListLayout");
				const currentLayout = savedLayout || defaultPostListLayout;
				mainGrid.setAttribute("data-layout-mode", currentLayout);

				if (currentLayout === "grid") {
					const rightSidebar = document.querySelector(
						".right-sidebar-container",
					);
					if (rightSidebar) {
						rightSidebar.classList.add("hidden-in-grid-mode");
					}
				}
			}
		});
	}
</script>

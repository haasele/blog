# Mizuki blog environment variable example
# Copy this file to .env and fill in actual values as needed

# ============================================
# Content repository configuration (code/content separation)
# Project: https://github.com/matsuzaka-yuki/Mizuki-Content
# ============================================

# Enable content separation (true/false)
# true: enable content separation, sync content from a separate repository
# false: disable content separation, use local content (default mode)
# Note: if you do not use content separation, you can comment this out or set it to false
# ENABLE_CONTENT_SYNC=false

# Git URL of the content repository (required only when ENABLE_CONTENT_SYNC=true)
# Supports HTTPS and SSH:
# HTTPS: https://github.com/your-username/Mizuki-Content.git
# SSH: git@github.com:your-username/Mizuki-Content.git
# CONTENT_REPO_URL=https://github.com/your-username/Mizuki-Content.git

# Content directory path (relative to project root)
# Default: ./content — usually no change needed
CONTENT_DIR=./content

# ============================================
# Auto build trigger configuration (when content repo updates)
# ============================================

# Problem: content repo updates do not automatically trigger code repo deployment
# Solution: configure an auto-trigger mechanism; Repository Dispatch is recommended
# See: docs/AUTO_BUILD_TRIGGER.md (5-step quick setup)

# ============================================
# IndexNow SEO configuration
# ============================================

# IndexNow API key for submitting URL updates to search engines
# INDEXNOW_KEY=asdf1213456
# Site host address
# INDEXNOW_HOST=your.example.com

# ============================================
# Bilibili configuration (for watch progress)
# ============================================

# How to obtain SESSDATA:
# 1. Log in to your Bilibili account
# 2. Open browser developer tools (F12 or Ctrl+Shift+I)
# 3. Go to the Application tab
# 4. Find the cookie field in request headers
# 5. Extract the sessdata value from the cookie

# Environment variable name: BILI_SESSDATA     key value: sessdata
# BILI_SESSDATA=your_bilibili_sessdata
